  "item": [
    {
      "name": "Get Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"Users array exists\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData).to.have.property(\"users\");\r",
              "    pm.expect(jsonData.users).to.be.an(\"array\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "",
            "value": "",
            "type": "text",
            "disabled": true
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create  User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains firstName\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.firstName).to.eql(\"Joseph\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains lastName\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.lastName).to.eql(\"Titilayo\");\r",
              "});\r",
              "\r",
              "pm.test(\"Age is correct\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.age).to.eql(25);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstName\": \"Joseph\",\r\n    \"lastName\": \"Titilayo\",\r\n    \"age\": 25\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users/add",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "add"
          ]
        }
      },
      "response": []
    },
    {
      "name": "DELETE User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"User was deleted\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData.isDeleted).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.test(\"Deleted user ID is correct\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData.id).to.eql(2);\r",
              "});\r",
              "\r",
              "pm.test(\"Deletion date exists\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData).to.have.property(\"deletedOn\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "2"
          ]
        }
      },
      "response": []
    }
  ]
}